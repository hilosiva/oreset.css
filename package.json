{
  "name": "oreset-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "test": "pnpm -r run test",
    "publish:oreset": "pnpm --filter @hilosiva/oreset publish",
    "publish:mcp": "pnpm --filter @hilosiva/oreset-mcp publish",
    "publish:all": "pnpm --filter @hilosiva/oreset publish && pnpm --filter @hilosiva/oreset-mcp publish"
  }
}
